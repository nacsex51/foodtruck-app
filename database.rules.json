{
  "rules": {
    "orders": {
      ".read": "auth != null",

      "$orderId": {
        ".write": "auth != null && (!data.exists() || !newData.exists())",

        ".validate": "newData.hasChildren(['queue', 'items', 'status', 'timestamp'])",

        "queue": {
          ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 16"
        },

        "status": {
          ".write": "auth != null",
          ".validate": "newData.val() === 'new' || newData.val() === 'done'"
        },

        "timestamp": {
          ".validate": "newData.isNumber()"
        },

        "items": {
          ".validate": "newData.hasChildren()",
          "$itemIndex": {
            ".validate": "newData.hasChildren(['name', 'qty', 'price'])",
            "name": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length < 60"
            },
            "qty": {
              ".validate": "newData.isNumber() && newData.val() > 0 && newData.val() <= 50"
            },
            "price": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000"
            },
            "note": {
              ".validate": "newData.isString() && newData.val().length <= 300"
            },
            "$other": {
              ".validate": false
            }
          }
        },

        "$other": {
          ".validate": false
        }
      }
    },

    "dailyStats": {
      ".read": "auth != null",
      ".write": "auth != null",

      "orderCount": {
        ".validate": "newData.isNumber()"
      },
      "doneCount": {
        ".validate": "newData.isNumber()"
      },
      "items": {
        "$itemName": {
          ".validate": "newData.isNumber()"
        }
      },
      "$other": {
        ".validate": false
      }
    }
  }
}
